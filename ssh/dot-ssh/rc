#!/bin/sh

# Pin the auth socket to a fixed path so tmux sessions survive re-attachment.
# Each new SSH connection updates the symlink to the current real socket.
if [ -n "$SSH_AUTH_SOCK" ] && [ "$SSH_AUTH_SOCK" != "$HOME/.ssh/auth.sock" ]; then
    ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/auth.sock"
fi
