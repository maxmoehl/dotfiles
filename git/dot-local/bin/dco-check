#!/usr/bin/env perl
use strict;
use warnings;

my @PREFIXES = qw(
    github.com/ironcore-dev/
    github.com/sap-contributions/ironcore
);

my $remote_name = $ARGV[0] // "";
if ($remote_name eq "") {
    STDERR->printf("dco-check: no remote_name given\n");
    exit(1);
}

my $remote_url = $ARGV[1] // "";
if ($remote_url eq "") {
    STDERR->printf("dco-check: no remote_url given\n");
    exit(1);
}

my $normalized = "";
if ($remote_url =~ m{^https?://([^/]+)(/.+)}) {
    $normalized = "$1$2";
} elsif ($remote_url =~ m{^[^@]+@([^:]+):(.+)}) {
    $normalized = "$1/$2";
} else {
    STDERR->printf("dco-check: could not process remote URL '$remote_url'\n");
    exit(1);
}

my $prefix_matches = 0;
for my $prefix (@PREFIXES) {
    if (index($normalized, $prefix) == 0) {
        $prefix_matches = 1;
        last;
    }
}

if (!$prefix_matches) {
    exit(0);
}

while (my $line = <STDIN>) {
    chomp($line);
    my ($local_ref, $local_sha, $remote_ref, $remote_sha) = split(/\s+/, $line);

    next if ($local_sha =~ /^0+$/);

    my $rev_list_cmd;
    if ($remote_sha =~ /^0+$/) {
        $rev_list_cmd = "git rev-list $local_sha --not --remotes=$remote_name";
    } else {
        $rev_list_cmd = "git rev-list $remote_sha..$local_sha";
    }

    my @commits = split(/\n/, `$rev_list_cmd`);
    for my $sha (@commits) {
        my $message = `git log -1 --format=%B $sha`;
        if ($message !~ /^Signed-off-by:\s+.+\s+<.+>/m) {
            STDERR->print("dco-check: $sha: missing Signed-off-by trailer\n");
            exit(1);
        }
    }
}

STDERR->print("dco-check: passed\n");
